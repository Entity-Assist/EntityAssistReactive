# ── Runtime ──────────────────────────────────────────────────────────
ENVIRONMENT=dev
PORT=8080

# ── Database ─────────────────────────────────────────────────────────
# Database connections are configured in GuicedEE DatabaseModule implementations
# (see src/test/java/com/test/EntityAssistReactiveDBModule.java for an example).
# These variables can be read inside your DatabaseModule's getConnectionBaseInfo().
DB_HOST=localhost
DB_PORT=5432
DB_NAME=entityassist
DB_USER=postgres
DB_PASSWORD=

# ── Observability ───────────────────────────────────────────────────
TRACING_ENABLED=false
ENABLE_DEBUG_LOGS=false

# ── Testing ─────────────────────────────────────────────────────────
TEST_DB_CONTAINER_IMAGE=postgres:latest
SKIP_INTEGRATION_TESTS=true
